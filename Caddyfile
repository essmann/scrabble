scrabble.loseyourip.com {
	# Log all requests
	log {
		output file ./caddy_logs.json
		format json
	}

	# API requests
	handle /api* {
		uri strip_prefix /api
		reverse_proxy localhost:3000
	}

	# Everything else (frontend) - with WebSocket support
	handle {
		reverse_proxy localhost:5173 {
			transport http {
				versions 1.1
			}
		}
	}
}
